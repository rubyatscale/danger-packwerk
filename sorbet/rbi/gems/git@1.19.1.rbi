  # @example Check if lib/git.rb is deleted.
  #     deleted?('lib/git.rb')
  # @return [Boolean]
  #
  # pkg:gem/git#lib/git/status.rb:72
  def deleted?(file); end

  # pkg:gem/git#lib/git/status.rb:123
  def each(&block); end

  # pkg:gem/git#lib/git/status.rb:97
  def pretty; end

  # pkg:gem/git#lib/git/status.rb:106
  def pretty_file(file); end

  # Returns an Enumerable containing files that are not tracked in git.
