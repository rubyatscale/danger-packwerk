  # @example Check if lib/git.rb has changed.
  #     changed?('lib/git.rb')
  # @return [Boolean]
  #
  # pkg:gem/git#lib/git/status.rb:30
  def changed?(file); end

  # Returns an Enumerable containing files that have been deleted.
  # File path starts at git base directory
