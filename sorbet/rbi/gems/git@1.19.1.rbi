  # @example Check if lib/git.rb is added.
  #     added?('lib/git.rb')
  # @return [Boolean]
  #
  # pkg:gem/git#lib/git/status.rb:51
  def added?(file); end

  # Returns an Enumerable containing files that have changed from the
