    # pkg:gem/danger#lib/danger/ci_source/screwdriver.rb:29
    def validates_as_ci?(env); end

    # pkg:gem/danger#lib/danger/ci_source/screwdriver.rb:33
    def validates_as_pr?(env); end
  end
end

