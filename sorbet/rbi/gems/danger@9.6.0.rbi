  # pkg:gem/danger#lib/danger/ci_source/xcode_server.rb:31
  def supported_request_sources; end

  class << self
    # pkg:gem/danger#lib/danger/ci_source/xcode_server.rb:22
    def validates_as_ci?(env); end

    # pkg:gem/danger#lib/danger/ci_source/xcode_server.rb:26
    def validates_as_pr?(env); end
  end
end

