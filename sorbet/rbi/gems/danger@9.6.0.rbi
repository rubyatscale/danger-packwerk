# Wraps an exception raised by a DSL file in order to show to the user the
# contents of the line that raised the exception.
#
# pkg:gem/danger#lib/danger/danger_core/standard_error.rb:14
class Danger::DSLError < ::StandardError
  # @param [Exception] backtrace @see backtrace
  # @param [String]    dsl_path  @see dsl_path
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:31
  def initialize(description, dsl_path, backtrace, contents = T.unsafe(nil)); end

  # @return [Exception] the backtrace of the exception raised by the
  #         evaluation of the dsl file.
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:26
  def backtrace; end

  # @return [String] the contents of the DSL that cause the exception to
  #         be raised.
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:41
  def contents; end

  # @return [String] the description that should be presented to the user.
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:17
  def description; end

  # @return [String] the path of the dsl file that raised the exception.
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:21
  def dsl_path; end

  # The message of the exception reports the content of podspec for the
  # line that generated the original exception.
  #
  # @example Output
  #
  #   Invalid podspec at `RestKit.podspec` - undefined method
  #   `exclude_header_search_paths=' for #<Pod::Specification for
  #   `RestKit/Network (0.9.3)`>
  #
  #       from spec-repos/master/RestKit/0.9.3/RestKit.podspec:36
  #       -------------------------------------------
  #           # because it would break: #import <CoreData/CoreData.h>
  #    >      ns.exclude_header_search_paths = 'Code/RestKit.h'
  #         end
  #       -------------------------------------------
  #
  # @return [String] the message of the exception.
  #
  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:63
  def message; end

  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:74
  def to_markdown; end

  private

  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:94
  def parse; end

  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:129
  def parse_line_number_from_description; end

  # pkg:gem/danger#lib/danger/danger_core/standard_error.rb:138
  def upgrade_message(latest_version); end
end

